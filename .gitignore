# Build output
**/target
test-results/
research/

# Editor / IDE — personal files stay ignored, but the shared rust-analyzer
# feature config is checked in (rsac-4f0d): without it, feature-gated code
# (src/compose/, src/main.rs, gated examples) gets no diagnostics.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Binding smoke-test scratch (ci.yml check-bindings + local runs, rsac-e1f7)
.venv-smoke/
bindings/rsac-napi/package-lock.json

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev-debug.log

# Node.js
node_modules/

# Environment variables
.env
.env.local

# OS-specific
.DS_Store

# Test / audio artifacts (auto-downloaded or captured during test runs —
# scripts/download_test_audio.sh + src/bin/standardized_test.rs know how
# to fetch these on demand; no need to commit them.)
*.wav
*.mp3
capture*.txt
test_audio/
system_audio*.wav
dynamic_vlc_capture*.wav

# Windows VM storage (docker/dockur/windows)
windows-storage/

# Stale tool-cache dirs
.upstream-refs/

# Kilo agent state (worktrees, manager state, node_modules) — only committed
# plans (.kilo/plans/) are tracked; everything else is machine-local.
.kilo/*
!.kilo/plans/

# audio-graph now depends on rsac (submodule relationship reversed) —
# this checkout is a standalone repo, not tracked here.
/apps/
