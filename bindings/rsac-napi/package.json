{
  "name": "@rsac/audio",
  "version": "0.1.0",
  "description": "Node.js/TypeScript bindings for rsac — Rust Cross-Platform Audio Capture",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "artifacts": "napi artifacts",
    "version": "napi version"
  },
  "napi": {
    "name": "rsac-audio",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0-alpha.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Codeseys-Labs/rust-crossplat-audio-capture"
  },
  "keywords": [
    "audio",
    "capture",
    "wasapi",
    "pipewire",
    "coreaudio",
    "napi",
    "rust"
  ]
}
