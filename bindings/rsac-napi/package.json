{
  "name": "@rsac/audio",
  "version": "0.2.0",
  "description": "Node.js bindings for rsac (Rust cross-platform audio capture)",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "artifacts": "napi artifacts",
    "version": "napi version",
    "test": "node --test tests"
  },
  "napi": {
    "name": "rsac-audio",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "license": "MIT OR Apache-2.0",
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baladita/rust-crossplat-audio-capture.git"
  },
  "keywords": [
    "audio",
    "capture",
    "wasapi",
    "coreaudio",
    "pipewire",
    "napi",
    "rust"
  ]
}
